# Kaggle API credentials (get from https://www.kaggle.com/settings/account)
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_api_key

# MLflow
MLFLOW_TRACKING_URI=sqlite:///mlflow.db
MLFLOW_EXPERIMENT_NAME=course-recommender-ab-test

# Model settings
VARIANT_A_MODEL=all-MiniLM-L6-v2
VARIANT_B_MODEL=all-mpnet-base-v2
